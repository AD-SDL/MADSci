# Secrets and environment-specific overrides for Example Lab
#
# Default configuration lives in settings.yaml (version-controlled).
# Use this file only for secrets, credentials, and local overrides.
#
# NOTE: The *.manager.yaml definition files in managers/ are the legacy
# configuration pattern. This lab uses settings.yaml + .env instead.
# The definition files are kept as backward-compatible examples.
# See docs/guides/migration_from_definitions.md for details.

### Infrastructure (used by Docker Compose)

# USER_ID=1000
# GROUP_ID=1000
# REPO_PATH="./"
# REDIS_PORT=6379
# DOCUMENT_DB_PORT=27017
# POSTGRES_PORT=5432
# OBJECT_STORAGE_PORT=8333
# OBJECT_STORAGE_CONSOLE_PORT=9333

### Database credentials

RESOURCE_DB_URL=postgresql://madsci:madsci@localhost:5432/postgres

# FerretDB (MongoDB-compatible) requires authentication via its PostgreSQL backend.
# This is shared by Event, Experiment, Data, and Workcell managers.
DOCUMENT_DB_URL=mongodb://madsci:madsci@localhost:27017/

### Object storage (SeaweedFS)

OBJECT_STORAGE_ENDPOINT=http://localhost:8333
OBJECT_STORAGE_ACCESS_KEY=madsci
OBJECT_STORAGE_SECRET_KEY=madsci
OBJECT_STORAGE_DEFAULT_BUCKET=madsci-data

### OpenTelemetry

DATA_OTEL_ENABLED=true
DATA_OTEL_SERVICE_NAME="madsci.data"
DATA_OTEL_EXPORTER="otlp"
DATA_OTEL_ENDPOINT="http://localhost:4317"
DATA_OTEL_PROTOCOL="grpc"

EVENT_OTEL_ENABLED=true
EVENT_OTEL_SERVICE_NAME="madsci.event"
EVENT_OTEL_EXPORTER="otlp"
EVENT_OTEL_ENDPOINT="http://localhost:4317"
EVENT_OTEL_PROTOCOL="grpc"

WORKCELL_OTEL_ENABLED=true
WORKCELL_OTEL_SERVICE_NAME="madsci.workcell"
WORKCELL_OTEL_EXPORTER="otlp"
WORKCELL_OTEL_ENDPOINT="http://localhost:4317"
WORKCELL_OTEL_PROTOCOL="grpc"

EXPERIMENT_OTEL_ENABLED=true
EXPERIMENT_OTEL_SERVICE_NAME="madsci.experiment"
EXPERIMENT_OTEL_EXPORTER="otlp"
EXPERIMENT_OTEL_ENDPOINT="http://localhost:4317"
EXPERIMENT_OTEL_PROTOCOL="grpc"

RESOURCE_OTEL_ENABLED=true
RESOURCE_OTEL_SERVICE_NAME="madsci.resource"
RESOURCE_OTEL_EXPORTER="otlp"
RESOURCE_OTEL_ENDPOINT="http://localhost:4317"
RESOURCE_OTEL_PROTOCOL="grpc"

LAB_OTEL_ENABLED=true
LAB_OTEL_SERVICE_NAME="madsci.lab"
LAB_OTEL_EXPORTER="otlp"
LAB_OTEL_ENDPOINT="http://localhost:4317"
LAB_OTEL_PROTOCOL="grpc"

LOCATION_OTEL_ENABLED=true
LOCATION_OTEL_SERVICE_NAME="madsci.location"
LOCATION_OTEL_EXPORTER="otlp"
LOCATION_OTEL_ENDPOINT="http://localhost:4317"
LOCATION_OTEL_PROTOCOL="grpc"
