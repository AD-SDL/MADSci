{
    "database": "madsci_locations",
    "schema_version": "1.0.0",
    "description": "Schema definition for MADSci Location Manager MongoDB",
    "collections": {
      "locations": {
        "description": "Locations managed by this Location Manager",
        "indexes": [
          {
            "keys": [["location_name", 1]],
            "name": "location_name_unique",
            "unique": true,
            "description": "Unique constraint on location names"
          },
          {
            "keys": [["location_id", 1]],
            "name": "location_id_unique",
            "unique": true,
            "description": "Unique constraint on location IDs"
          }
        ]
      },
      "schema_versions": {
        "description": "Version tracking for schema migrations",
        "indexes": [
          {
            "keys": [["version", 1]],
            "name": "version_unique",
            "unique": true,
            "description": "Unique constraint on version strings"
          },
          {
            "keys": [["applied_at", -1]],
            "name": "applied_at_desc",
            "description": "Index for chronological version tracking"
          }
        ]
      }
    }
  }
