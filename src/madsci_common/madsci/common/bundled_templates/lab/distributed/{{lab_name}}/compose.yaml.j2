# Docker Compose configuration for {{ lab_name }}
#
# Generated by: madsci new lab --template distributed
# Template version: {{ template_version }}
#
# Usage:
#   docker compose up -d          # Start all services
#   docker compose down            # Stop all services
#   docker compose logs -f         # Follow all logs

services:
  # --- Infrastructure ---

  postgres:
    image: ghcr.io/ferretdb/postgres-documentdb-dev:17-ferretdb
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-madsci}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-madsci}
      POSTGRES_DB: ${POSTGRES_DB:-postgres}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U madsci"]
      interval: 5s
      timeout: 5s
      retries: 5

  ferretdb:
    image: ghcr.io/ferretdb/ferretdb:2
    ports:
      - "27017:27017"
    environment:
      - FERRETDB_POSTGRESQL_URL=postgres://madsci:madsci@postgres:5432/postgres
    depends_on:
      postgres:
        condition: service_healthy

  valkey:
    image: valkey/valkey:8
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5

  # --- MADSci Managers ---

  lab_manager:
    image: madsci-squid:latest
    build:
      context: .
      dockerfile: Dockerfile.squid
    ports:
      - "8000:8000"
    env_file: .env
    depends_on:
      ferretdb:
        condition: service_started

  event_manager:
    image: madsci-event-manager:latest
    ports:
      - "8001:8001"
    env_file: .env
    depends_on:
      ferretdb:
        condition: service_started

  experiment_manager:
    image: madsci-experiment-manager:latest
    ports:
      - "8002:8002"
    env_file: .env
    depends_on:
      ferretdb:
        condition: service_started

  resource_manager:
    image: madsci-resource-manager:latest
    ports:
      - "8003:8003"
    env_file: .env
    depends_on:
      postgres:
        condition: service_healthy

  data_manager:
    image: madsci-data-manager:latest
    ports:
      - "8004:8004"
    env_file: .env
    depends_on:
      ferretdb:
        condition: service_started

  workcell_manager:
    image: madsci-workcell-manager:latest
    ports:
      - "8005:8005"
    env_file: .env
    depends_on:
      ferretdb:
        condition: service_started
      valkey:
        condition: service_healthy

  location_manager:
    image: madsci-location-manager:latest
    ports:
      - "8006:8006"
    env_file: .env
    depends_on:
      ferretdb:
        condition: service_started

volumes:
  postgres_data:
