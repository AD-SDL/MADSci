# Environment configuration for {{ lab_name }}
#
# Generated by: madsci new lab --template distributed

# Lab Configuration
LAB_NAME={{ lab_name }}
LAB_DESCRIPTION="{{ lab_description }}"

# Manager Host (set this to the manager server's IP/hostname)
MANAGER_HOST=localhost

# Lab Manager (Squid)
LAB_SERVER_URL=http://${MANAGER_HOST}:8000/

# Event Manager
EVENT_SERVER_URL=http://${MANAGER_HOST}:8001/
EVENT_MONGO_DB_URL=mongodb://${MANAGER_HOST}:27017/
EVENT_DATABASE=events

# Experiment Manager
EXPERIMENT_SERVER_URL=http://${MANAGER_HOST}:8002/
EXPERIMENT_MONGO_DB_URL=mongodb://${MANAGER_HOST}:27017/
EXPERIMENT_DATABASE=experiments

# Resource Manager
RESOURCE_SERVER_URL=http://${MANAGER_HOST}:8003/
RESOURCE_DB_URL=postgresql://{{ db_user }}:{{ db_password }}@${MANAGER_HOST}:5432/resources

# Data Manager
DATA_SERVER_URL=http://${MANAGER_HOST}:8004/
DATA_MONGO_DB_URL=mongodb://${MANAGER_HOST}:27017/
DATA_DATABASE=data

# Workcell Manager
WORKCELL_SERVER_URL=http://${MANAGER_HOST}:8005/
WORKCELL_MONGO_DB_URL=mongodb://${MANAGER_HOST}:27017/
WORKCELL_DATABASE=workcells

# Location Manager
LOCATION_SERVER_URL=http://${MANAGER_HOST}:8006/
LOCATION_MONGO_DB_URL=mongodb://${MANAGER_HOST}:27017/
LOCATION_DATABASE=locations

# Infrastructure
# WARNING: Change these credentials for production use!
POSTGRES_USER={{ db_user }}
POSTGRES_PASSWORD={{ db_password }}
POSTGRES_DB=resources
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
REDIS_URL=redis://${MANAGER_HOST}:6379/0
