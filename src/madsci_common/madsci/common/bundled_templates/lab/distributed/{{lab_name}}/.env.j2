# Secrets and environment-specific overrides for {{ lab_name }}
# This file is gitignored -- do NOT commit it.
#
# Default configuration lives in settings.yaml (version-controlled).
# Use this file only for secrets, credentials, and local overrides.
#
# Generated by: madsci new lab --template distributed

# Lab metadata (used by scripts, not by settings.yaml)
LAB_NAME={{ lab_name }}
LAB_DESCRIPTION="{{ lab_description }}"

# Manager Host (set this to the manager server's IP/hostname for distributed mode)
MANAGER_HOST=localhost

# Override manager URLs for distributed deployments
# Uncomment and update these if your managers run on a remote host:
# LAB_SERVER_URL=http://${MANAGER_HOST}:8000/
# EVENT_SERVER_URL=http://${MANAGER_HOST}:8001/
# EXPERIMENT_SERVER_URL=http://${MANAGER_HOST}:8002/
# RESOURCE_SERVER_URL=http://${MANAGER_HOST}:8003/
# DATA_SERVER_URL=http://${MANAGER_HOST}:8004/
# WORKCELL_SERVER_URL=http://${MANAGER_HOST}:8005/
# LOCATION_SERVER_URL=http://${MANAGER_HOST}:8006/

# Database credentials
# WARNING: Change these credentials for production use!
POSTGRES_USER={{ db_user }}
POSTGRES_PASSWORD={{ db_password }}
POSTGRES_DB=postgres

# Resource Manager DB connection (contains credentials)
RESOURCE_DB_URL=postgresql://{{ db_user }}:{{ db_password }}@${MANAGER_HOST}:5432/postgres

# FerretDB (MongoDB-compatible) document database connection (requires authentication).
# Shared by Event, Experiment, Data, and Workcell managers.
DOCUMENT_DB_URL=mongodb://{{ db_user }}:{{ db_password }}@${MANAGER_HOST}:27017/

# Valkey (Redis-compatible)
REDIS_URL=redis://${MANAGER_HOST}:6379/0
