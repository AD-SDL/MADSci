# Secrets and environment-specific overrides for {{ lab_name }}
# This file is gitignored -- do NOT commit it.
#
# Default configuration lives in settings.yaml (version-controlled).
# Use this file only for secrets, credentials, and local overrides.
#
# Generated by: madsci new lab --template standard

# Lab metadata (used by scripts, not by settings.yaml)
LAB_NAME={{ lab_name }}
LAB_DESCRIPTION="{{ lab_description }}"

# Database credentials (used by Docker Compose infrastructure)
POSTGRES_USER=madsci
POSTGRES_PASSWORD=madsci
POSTGRES_DB=postgres

# Resource Manager DB connection (contains credentials)
RESOURCE_DB_URL=postgresql://madsci:madsci@localhost:5432/postgres

# FerretDB (MongoDB-compatible) document database connection (requires authentication).
# Shared by Event, Experiment, Data, and Workcell managers.
DOCUMENT_DB_URL=mongodb://madsci:madsci@localhost:27017/

# Valkey (Redis-compatible)
REDIS_URL=redis://localhost:6379/0
