MONGO_INITDB_ROOT_PASSWORD=

# Resource Manager DB connection (contains credentials)
RESOURCE_DB_URL=postgresql://madsci:madsci@localhost:5432/resources

# Redis
REDIS_URL=redis://localhost:6379/0
