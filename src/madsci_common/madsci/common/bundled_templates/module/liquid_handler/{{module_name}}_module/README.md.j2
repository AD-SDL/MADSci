    resource_name="{{ module_name }}_tip_pool",
    resource_class="{{ module_name | pascal_case }}TipPool",
    capacity=96.0,
    attributes={"description": "Pool of disposable tips"},
)

self.resource_client.init_template(
    resource=tip_pool,
    template_name="{{ module_name }}_tip_pool",
    description="Template for {{ module_name }} tip pool.",
    required_overrides=["resource_name"],
    tags=["{{ module_name }}", "tips", "pool"],
    created_by=self.node_definition.node_id,
    version="1.0.0",
)
```

