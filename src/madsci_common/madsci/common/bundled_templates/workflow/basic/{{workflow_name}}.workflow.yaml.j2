# Generated by: madsci new workflow --template workflow/basic
# Template version: {{ template_version }}

name: {{ workflow_name }}

metadata:
  description: "{{ workflow_description }}"
  version: "1.0.0"

# Workflow parameters (passed in when starting the workflow)
parameters:
  json_inputs:
    - key: message
      description: "Message to pass to the action"
      default: "Hello from {{ workflow_name }}!"

# Workflow steps
steps:
  - name: step_1
    description: "Execute {{ action_name }} on {{ node_name }}"
    node: {{ node_name }}
    action: {{ action_name }}
    args:
      message: "${{ '{' }}parameters.message{{ '}' }}"
